{
	"name": "front",
	"version": "0.0.1",
	"license": "MIT",
	"private": false,
	"description": "Front de la App SovereingSchool",
	"keywords": [
		"angular",
		"front",
		"web-obs",
		"obs",
		"video",
		"audio",
		"broadcast",
		"live-streaming",
		"streaming",
		"web-component"
