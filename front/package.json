	"repository": {
		"type": "git",
		"url": "https://github.com/giacca90/sovereing-school/tree/main/front"
	},
	"scripts": {
		"dev": "clear && concurrently -k -n NG,PROXY -c green,blue \"NODE_TLS_REJECT_UNAUTHORIZED=0 ng serve --ssl --ssl-cert ./cert.pem --ssl-key ./key.pem --no-hmr\" \"node proxy-dev.js\"",
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build && npm run license-report",
		"watch": "ng build --watch --configuration development",
		"test": "ng test",
		"serve:ssr:front": "node dist/front/server/server.mjs",
		"lint": "ng lint",
		"release:patch": "npm version patch",
		"release:minor": "npm version minor",
		"release:major": "npm version major",
		"license-report": "license-checker --txt --out THIRD-PARTY-LICENSES.txt"
	},
